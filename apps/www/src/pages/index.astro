    <script>
      import { setupHomepageShaders } from '../homepage-shaders';

      setupHomepageShaders();

      // --- Nav tagline scroll reveal -----------------------------------------
      // Slides the tagline in from below the "Flue" wordmark once the user
      // scrolls past the hero, giving the nav a subtle personality boost.
      const tagline = document.querySelector('#nav-tagline span');
      if (tagline) {
        window.addEventListener('scroll', () => {
          const show = window.scrollY > 200;
          tagline.classList.toggle('translate-y-full', !show);
          tagline.classList.toggle('opacity-0', !show);
          tagline.classList.toggle('translate-y-0', show);
          tagline.classList.toggle('opacity-100', show);
        }, { passive: true });
      }

      const copyPromptBtn = document.getElementById('copy-prompt-btn');
      const copyPromptSrc = document.getElementById('copy-prompt-text');
      const copyPromptShell = document.getElementById('copy-prompt-shell');
      if (copyPromptBtn && copyPromptSrc && copyPromptShell) {
        const prompt = (copyPromptSrc.textContent ?? '').trim();
        let resetTimer: ReturnType<typeof setTimeout> | undefined;

        copyPromptBtn.addEventListener('click', async () => {
          let copied = false;
          try {
            await navigator.clipboard.writeText(prompt);
            copied = true;
          } catch {
            const textarea = document.createElement('textarea');
            textarea.value = prompt;
            textarea.setAttribute('readonly', '');
            textarea.style.cssText = 'position:absolute;left:-9999px;top:-9999px;';
            document.body.appendChild(textarea);
            textarea.select();
            try { copied = document.execCommand('copy'); } catch {}
            textarea.remove();
          }
          copyPromptShell.dataset.copyError = String(!copied);
          copyPromptShell.dataset.feedback = 'true';
          clearTimeout(resetTimer);
          resetTimer = setTimeout(() => {
            copyPromptShell.dataset.feedback = 'false';
          }, 5000);
        });
      }


      const ecosystemGridShell = document.getElementById('ecosystem-grid-shell');
      const ecosystemGrid = document.getElementById('ecosystem-grid');
      const ecosystemGridFade = document.getElementById('ecosystem-grid-fade');
      const ecosystemShowMore = document.getElementById('ecosystem-show-more');
      if (ecosystemGridShell && ecosystemGrid && ecosystemGridFade && ecosystemShowMore) {
        const setEcosystemGridHeight = (expanded: boolean, animate = true) => {
          const firstItem = ecosystemGrid.querySelector<HTMLElement>('li');
          if (!firstItem) return;
          const rowHeight = firstItem.getBoundingClientRect().height;
          const rowGap = Number.parseFloat(getComputedStyle(ecosystemGrid).rowGap) || 0;
          const mobile = window.matchMedia('(max-width: 639px)').matches;
          const collapsedHeight = mobile ? ecosystemGrid.scrollHeight : rowHeight * 3 + rowGap * 2;
          if (!animate) ecosystemGridShell.style.transition = 'none';
          ecosystemGridShell.style.height = `${expanded ? ecosystemGrid.scrollHeight : Math.min(collapsedHeight, ecosystemGrid.scrollHeight)}px`;
          if (!animate) {
            ecosystemGridShell.getBoundingClientRect();
            ecosystemGridShell.style.removeProperty('transition');
          }
          ecosystemGridFade.classList.toggle('sm:hidden', expanded || ecosystemGrid.scrollHeight <= collapsedHeight);
          ecosystemShowMore.classList.toggle('sm:hidden', expanded || ecosystemGrid.scrollHeight <= collapsedHeight);
          for (const link of ecosystemGrid.querySelectorAll<HTMLAnchorElement>('a')) {
            const item = link.closest('li');
            if (!item) continue;
            const covered = !mobile && !expanded && item.offsetTop + item.offsetHeight > collapsedHeight - rowHeight;
            link.style.pointerEvents = covered ? 'none' : '';
            link.tabIndex = covered ? -1 : 0;
          }
        };

        setEcosystemGridHeight(false, false);
        window.addEventListener('resize', () => {
          setEcosystemGridHeight(ecosystemGridShell.dataset.expanded === 'true', false);
        });
        ecosystemShowMore.addEventListener('click', () => {
          ecosystemGridShell.dataset.expanded = 'true';
          setEcosystemGridHeight(true);
        });
      }

      const durCells = document.getElementById('durability-cells');
      const durStatus = document.getElementById('durability-status');
      const durFrame = document.getElementById('durability-frame');
      const durDisrupt = document.getElementById('durability-disrupt');
      if (durCells && durStatus && durFrame && durDisrupt) {
        const mobileColumns = 14;
        const desktopColumns = 20;
        const rows = 8;
        const mobileLayout = window.matchMedia('(max-width: 1023px)');
        const TOTAL = (mobileLayout.matches ? mobileColumns : desktopColumns) * rows;
        const cells: HTMLElement[] = [];
        for (let i = 0; i < TOTAL; i++) {
          const cell = document.createElement('div');
          cell.className = 'durability-cell';
          durCells.appendChild(cell);
          cells.push(cell);
        }

        const getColumns = () => mobileLayout.matches ? mobileColumns : desktopColumns;
        let visibleRows = mobileLayout.matches ? rows : 1;
        const setVisibleRows = (nextRows: number, animate = true) => {
          visibleRows = mobileLayout.matches ? rows : Math.max(1, Math.min(rows, nextRows));
          const firstCell = cells[0];
          if (!firstCell) return;
          const rowHeight = firstCell.getBoundingClientRect().height;
          const rowGap = Number.parseFloat(getComputedStyle(durCells).rowGap) || 0;
          if (!animate) durCells.style.transition = 'none';
          durCells.style.height = `${visibleRows * rowHeight + (visibleRows - 1) * rowGap}px`;
          if (!animate) {
            durCells.getBoundingClientRect();
            durCells.style.removeProperty('transition');
          }
        };
        setVisibleRows(visibleRows, false);
        window.addEventListener('resize', () => { setVisibleRows(visibleRows, false); });

        const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
        let statusFrame: number | undefined;
        const renderStatus = () => {
          statusFrame = undefined;
          const online = cells.filter((cell) => cell.dataset.state === 'online').length;
          const outageVisible = cells.some((cell) => cell.dataset.state === 'down' || cell.dataset.state === 'restarting');
          durStatus.textContent = `${online} agents online`;
          durStatus.classList.toggle('text-red-500', outageVisible);
          durStatus.classList.toggle('text-gray-500', !outageVisible);
          durFrame.classList.toggle('border-red-500', outageVisible);
          durFrame.classList.toggle('border-gray-300', !outageVisible);
        };
        const updateStatus = () => {
          if (statusFrame !== undefined) return;
          statusFrame = window.requestAnimationFrame(renderStatus);
        };
        const setState = (cell: HTMLElement, state: string) => {
          cell.dataset.state = state;
          updateStatus();
        };
        const setStates = (targets: HTMLElement[], state: string) => {
          targets.forEach((cell) => { cell.dataset.state = state; });
          updateStatus();
        };
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        let durabilityVisible = false;
        let started = false;

        const startDemo = () => {
          if (started) return;
          started = true;

          let initialized = 0;
          if (reducedMotion.matches) {
            setStates(cells, 'online');
            initialized = TOTAL;
            setVisibleRows(rows, false);
          }


          let outageActive = false;
          let recoveryGeneration = 0;
          let startupTimer: number | undefined;
          const recoveryTimers = new Map<HTMLElement, number[]>();
          const clearRecoveryTimers = (cell: HTMLElement) => {
            recoveryTimers.get(cell)?.forEach(window.clearTimeout);
            recoveryTimers.delete(cell);
          };
          const scheduleNextOnline = (delay: number) => {
            window.clearTimeout(startupTimer);
            startupTimer = window.setTimeout(bringNextOnline, delay);
          };
          const bringNextOnline = () => {
            if (!durabilityVisible || outageActive) {
              scheduleNextOnline(200);
              return;
            }

            const offline = cells.filter((cell) => !cell.dataset.state);
            if (offline.length === 0) return;

            const cell = offline[0];
            setState(cell, 'online');
            initialized += 1;
            const columns = getColumns();
            if (initialized % columns === 0 && initialized < TOTAL) {
              setVisibleRows(initialized / columns + 1);
            }

            const remainingRatio = (TOTAL - initialized) / TOTAL;
            const jitter = 0.2 + Math.random() * 2.3;
            const delay = Math.min(3000, 55 * jitter / Math.max(remainingRatio ** 1.6, 0.0001));
            scheduleNextOnline(delay);
          };
          bringNextOnline();

          const recover = async (affected: HTMLElement[]) => {
            const generation = ++recoveryGeneration;
            outageActive = true;
            window.clearTimeout(startupTimer);
            affected.forEach((cell) => {
              clearRecoveryTimers(cell);
              cell.classList.add('durability-cell-disrupted');
            });
            setStates(affected, 'down');
            await sleep(600);
            if (generation !== recoveryGeneration) return;
            setStates(affected, 'restarting');
            await sleep(300);
            if (generation !== recoveryGeneration) return;
            const columns = getColumns();
            const recoveryRows = Array.from({ length: Math.ceil(TOTAL / columns) }, () => [] as HTMLElement[]);
            affected.forEach((cell) => {
              recoveryRows[Math.floor(cells.indexOf(cell) / columns)].push(cell);
            });
            await Promise.all(recoveryRows.map(async (row, rowIndex) => {
              await sleep(rowIndex * 25);
              for (const cell of row) {
                if (generation !== recoveryGeneration) return;
                cell.classList.remove('durability-cell-disrupted');
                cell.classList.add('durability-cell-recovering');
                const onlineTimer = window.setTimeout(() => {
                  if (generation !== recoveryGeneration) return;
                  setState(cell, 'online');
                  const cleanupTimer = window.setTimeout(() => {
                    if (generation === recoveryGeneration) cell.classList.remove('durability-cell-recovering');
                    recoveryTimers.delete(cell);
                  }, 700);
                  recoveryTimers.set(cell, [cleanupTimer]);
                }, 500);
                recoveryTimers.set(cell, [onlineTimer]);
                await sleep(50);
              }
            }));
            await sleep(1200);
            if (generation !== recoveryGeneration) return;
            outageActive = false;
            scheduleNextOnline(500);
          };

          durDisrupt.addEventListener('click', () => {
            const active = cells.filter((cell) => cell.dataset.state);
            if (active.length === 0) return;
            recover(active);
          });

          let outageCount = 0;
          const runOutage = async () => {
            await sleep(5000);

            if (!durabilityVisible) {
              runOutage();
              return;
            }
            if (!outageActive) {
              const online = cells.filter((cell) => cell.dataset.state === 'online');
              if (online.length > 0) {
                outageCount += 1;
                const takeAllDown = outageCount === 1 || Math.random() < 0.3;
                let affected: HTMLElement[];
                if (takeAllDown) {
                  affected = online;
                } else {
                  const outagePercent = 0.01 + Math.random() * 0.24;
                  const outageSize = Math.max(1, Math.ceil(online.length * outagePercent));
                  affected = [...online]
                    .sort(() => Math.random() - 0.5)
                    .slice(0, outageSize)
                    .sort((a, b) => cells.indexOf(a) - cells.indexOf(b));
                }
                await recover(affected);
              }
            }

            runOutage();
          };
          runOutage();
        };

        if ('IntersectionObserver' in window) {
          const durObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              durabilityVisible = entry.isIntersecting;
              if (entry.isIntersecting) startDemo();
            });
          }, { threshold: 0.4 });
          durObserver.observe(durCells);
        } else {
          durabilityVisible = true;
          startDemo();
        }
      }

      // --- Architecture cards: staggered entrance pulse ----------------------
      // Fires once when the architecture diagram scrolls into view.
      const archSection = document.querySelector('.pattern-layer')?.closest('section');
      if (archSection && 'IntersectionObserver' in window) {
        const pulseObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const cards = archSection.querySelectorAll<HTMLElement>('.pattern-layer');
              cards.forEach((card) => card.classList.add('card-pulse'));
              pulseObserver.disconnect();
            });
          },
          { threshold: 0.75 }
        );
        pulseObserver.observe(archSection);
      }
    </script>

    <style is:global>
      /* One-time entrance pulse for architecture cards. */
      @keyframes cardPulse {
        0%   { transform: translateY(0) scale(1); }
        50%  { transform: translateY(-6px) scale(1.02); }
        100% { transform: translateY(0) scale(1); }
      }
      .pattern-layer.card-pulse {
        animation: cardPulse 600ms ease-out forwards;
      }

      .chip-pixel {
        opacity: 0.14;
        animation: chipFlicker 4s steps(1, end) infinite;
      }
      @keyframes chipFlicker {
        0%, 12%, 44%, 100% { opacity: 0.14; }
        13%, 28% { opacity: 0.72; }
        29%, 43% { opacity: 0.38; }
        67%, 78% { opacity: 0.58; }
      }
      @media (prefers-reduced-motion: reduce) {
        .chip-pixel { animation: none; opacity: 0.45; }
        .durability-cell { transition: none; }
      }

      .durability-cell {
        aspect-ratio: 1 / 1;
        border-radius: 1px;
        background: #e2e8f0;
        transition: background-color 700ms ease;
      }
      .durability-cell-recovering { transition-duration: 700ms; }
      .durability-cell-disrupted { transition-duration: 300ms; }
      .durability-cell[data-state='online'] { background: #3b82f6; }
      .durability-cell[data-state='down'] { background: #ef4444; }
      .durability-cell[data-state='restarting'] { background: #94a3b8; }
    </style>

  </body>
</html>
