---
import "../styles/global.css";
import { Code } from "astro:components";
import { HERO, COPY_PROMPT } from "../code-snippets";

// Floating blueprint squares clustered near the hero headline. Coordinates
// are in the background SVG's 400x500 viewBox; all squares are 40x40px
// (2x2 grid units). `delay` staggers the entrance fade-in and the float
// loop so squares appear and pulse out of sync with each other.
const floatingSquares = [
  { x: 300, y: 120, opacity: 1.0, delay: 0.7, duration: 4 },
  { x: 220, y: 60,  opacity: 0.8, delay: 0.3, duration: 4 },
  { x: 160, y: 160, opacity: 0.5, delay: 0.0, duration: 4 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>Flue — The Agent Harness Framework</title>
    <meta name="description" content="Agent = Model + Harness. Build autonomous agents and powerful AI workflows with Flue's programmable TypeScript harness. Write once, deploy anywhere." />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href="https://flueframework.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Flue" />
    <meta property="og:title" content="Flue — The Agent Harness Framework" />
    <meta property="og:description" content="Agent = Model + Harness. Build autonomous agents and powerful AI workflows with Flue's programmable TypeScript harness. Write once, deploy anywhere." />
    <meta property="og:url" content="https://flueframework.com/" />
    <meta property="og:image" content="https://flueframework.com/og3.jpg" />
    <meta property="og:image:alt" content="Flue framework logo" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Flue — The Agent Harness Framework" />
    <meta name="twitter:description" content="Agent = Model + Harness. Build autonomous agents and powerful AI workflows with Flue's programmable TypeScript harness. Write once, deploy anywhere." />
    <meta name="twitter:image" content="https://flueframework.com/og3.jpg" />
    <meta name="twitter:image:alt" content="Flue framework logo" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-gray-950 font-[system-ui,sans-serif] antialiased">

    <!-- NAV -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-sm border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex h-full items-center gap-8">
          <a href="/" class="flex items-center gap-2">
            <svg class="size-6 shrink-0" viewBox="0 0 108 108" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="108" height="108" transform="matrix(-1 0 0 1 108 0)" fill="black"/>
              <rect width="18" height="18" transform="matrix(-1 0 0 1 72 18)" fill="white"/>
              <rect width="18" height="18" transform="matrix(-1 0 0 1 54 72)" fill="white"/>
              <rect width="18" height="18" transform="matrix(-1 0 0 1 54 36)" fill="white"/>
              <rect width="18" height="18" transform="matrix(-1 0 0 1 72 54)" fill="white"/>
            </svg>
            <span class="text-2xl font-extrabold tracking-tight text-gray-950 leading-8">Flue</span><span id="nav-tagline" class="overflow-hidden h-8 leading-8 lg:hidden"><span class="inline-block text-base sm:text-lg text-gray-500 translate-y-full opacity-0 transition-all duration-300 ease-out">the agent harness framework.</span></span>
          </a>
          <div class="hidden lg:flex h-full items-center gap-7 text-sm font-medium text-gray-500">
            <a href="/docs/getting-started/quickstart/" class="hover:text-blue-600 transition-colors">Guide</a>
            <a href="/docs/api/agent-api/" class="hover:text-blue-600 transition-colors">Reference</a>
            <a href="/docs/cli/overview/" class="hover:text-blue-600 transition-colors">CLI</a>
            <a href="/docs/sdk/overview/" class="hover:text-blue-600 transition-colors">SDK</a>
            <a href="/docs/ecosystem/overview/" class="hover:text-blue-600 transition-colors">Ecosystem</a>
          </div>
        </div>
        <div class="hidden sm:flex items-center gap-6">
          <a href="https://github.com/withastro/flue" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-950 transition-colors" aria-label="GitHub">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <!-- Blueprint background: construction grid (always visible) + floating
         squares (hidden on mobile). Rotated + scaled to feel like a drafting
         sheet behind the hero. -->
    <div class="absolute left-0 right-0 top-0 h-[1000px] pointer-events-none overflow-hidden -z-1">
      <div class="absolute top-[420px] left-1/2 transform -translate-y-1/3 rotate-16 scale-150 hidden lg:block">
        <svg width="700" height="850" viewBox="0 0 400 500" fill="none" overflow="visible" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#dddddd" stroke-width="1"/>
            </pattern>

            <!-- Gradient mask fades the grid from right to left, so it stays
                 present behind the visuals but recedes as it approaches the
                 body copy on the left. -->
            <linearGradient id="fadeLeft" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%"   stop-color="white" stop-opacity="0"/>
              <stop offset="35%"  stop-color="white" stop-opacity="0"/>
              <stop offset="70%"  stop-color="white" stop-opacity="1"/>
              <stop offset="90%"  stop-color="white" stop-opacity="0"/>
            </linearGradient>
            <mask id="fadeMask">
              <rect x="-200" y="-250" width="800" height="1000" fill="url(#fadeLeft)"/>
            </mask>

            <!-- Soft drop shadow to lift each square off the grid plane. -->
            <filter id="squareShadow" x="-75%" y="-75%" width="250%" height="250%">
              <feGaussianBlur in="SourceAlpha" stdDeviation="2.5"/>
              <feOffset dx="0" dy="2.5" result="offsetblur"/>
              <feComponentTransfer>
                <feFuncA type="linear" slope="0.22"/>
              </feComponentTransfer>
              <feMerge>
                <feMergeNode/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>

          <g mask="url(#fadeMask)">
            <rect x="-200" y="-250" width="800" height="1000" fill="url(#grid)"/>
          </g>
        </svg>
      </div>
    </div>

    <!-- HERO -->
    <section class="bg-transparent relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 pt-20 lg:pt-28 lg:pb-8 relative z-10">
        <h1 class="font-heading text-6xl  font-bold tracking-tight leading-[0.95]">
          The Agent Harness Framework
        </h1>
        <p class="mt-6 max-w-2xl lg:max-w-4xl text-xl text-gray-600 text-balance">
          Not another SDK. Build autonomous agents and powerful AI workflows with Flue's programmable TypeScript harness.
        </p>
        <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <div id="copy-prompt-shell" class="group/copy relative" data-feedback="false" data-copy-error="false">
            <button id="copy-prompt-btn" type="button" class="group inline-flex items-center gap-2.5 bg-gray-950 hover:bg-gray-800 rounded-full px-5 py-3 text-sm font-medium text-white transition-colors cursor-pointer">
              <span class="relative flex items-center justify-start shrink-0 text-white w-[94px] h-5" aria-hidden="true">
                <svg class="w-5 h-5 transition-transform duration-300 ease-out -rotate-6 group-hover:-rotate-12 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" xmlns="http://www.w3.org/2000/svg"><path d="M20.998 10.949H24v3.102h-3v3.028h-1.487V20H18v-2.921h-1.487V20H15v-2.921H9V20H7.488v-2.921H6V20H4.487v-2.921H3V14.05H0V10.95h3V5h17.998v5.949zM6 10.949h1.488V8.102H6v2.847zm10.51 0H18V8.102h-1.49v2.847z"/></svg>
                <svg class="w-5 h-5 ml-1 transition-transform duration-300 ease-out group-hover:-translate-x-0.5 group-hover:-translate-y-0.5 group-hover:rotate-6 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" xmlns="http://www.w3.org/2000/svg"><path d="M9.205 8.658v-2.26c0-.19.072-.333.238-.428l4.543-2.616c.619-.357 1.356-.523 2.117-.523 2.854 0 4.662 2.212 4.662 4.566 0 .167 0 .357-.024.547l-4.71-2.759a.797.797 0 00-.856 0l-5.97 3.473zm10.609 8.8V12.06c0-.333-.143-.57-.429-.737l-5.97-3.473 1.95-1.118a.433.433 0 01.476 0l4.543 2.617c1.309.76 2.189 2.378 2.189 3.948 0 1.808-1.07 3.473-2.76 4.163zM7.802 12.703l-1.95-1.142c-.167-.095-.239-.238-.239-.428V5.899c0-2.545 1.95-4.472 4.591-4.472 1 0 1.927.333 2.712.928L8.23 5.067c-.285.166-.428.404-.428.737v6.898zM12 15.128l-2.795-1.57v-3.33L12 8.658l2.795 1.57v3.33L12 15.128zm1.796 7.23c-1 0-1.927-.332-2.712-.927l4.686-2.712c.285-.166.428-.404.428-.737v-6.898l1.974 1.142c.167.095.238.238.238.428v5.233c0 2.545-1.974 4.472-4.614 4.472zm-5.637-5.303l-4.544-2.617c-1.308-.761-2.188-2.378-2.188-3.948A4.482 4.482 0 014.21 6.327v5.423c0 .333.143.571.428.738l5.947 3.449-1.95 1.118a.432.432 0 01-.476 0zm-.262 3.9c-2.688 0-4.662-2.021-4.662-4.519 0-.19.024-.38.047-.57l4.686 2.71c.286.167.571.167.856 0l5.97-3.448v2.26c0 .19-.07.333-.237.428l-4.543 2.616c-.619.357-1.356.523-2.117.523zm5.899 2.83a5.947 5.947 0 005.827-4.756C22.287 18.339 24 15.84 24 13.296c0-1.665-.713-3.282-1.998-4.448.119-.5.19-.999.19-1.498 0-3.401-2.759-5.947-5.946-5.947-.642 0-1.26.095-1.88.31A5.962 5.962 0 0010.205 0a5.947 5.947 0 00-5.827 4.757C1.713 5.447 0 7.945 0 10.49c0 1.666.713 3.283 1.998 4.448-.119.5-.19 1-.19 1.499 0 3.401 2.759 5.946 5.946 5.946.642 0 1.26-.095 1.88-.309a5.96 5.96 0 004.162 1.713z"/></svg>
                <svg class="w-5 h-5 ml-1 transition-transform duration-300 ease-out group-hover:translate-x-0.5 group-hover:translate-y-0.5 group-hover:-rotate-6 group-hover:scale-110" viewBox="82.65 82.65 634.71 634.71" fill="currentColor" fill-rule="evenodd" xmlns="http://www.w3.org/2000/svg"><path d="M165.29 165.29H517.36V400H400V517.36H282.65V634.72H165.29ZM282.65 282.65V400H400V282.65Z"/><path d="M517.36 400H634.72V634.72H517.36Z"/></svg>
                <svg class="w-5 h-5 ml-0.5 transition-transform duration-300 ease-out rotate-6 group-hover:rotate-12 group-hover:translate-x-1" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" xmlns="http://www.w3.org/2000/svg"><path d="M16 6H8v12h8V6zm4 16H4V2h16v20z"/></svg>
              </span>
              <span class="copy-prompt-label">Copy Prompt</span>
            </button>
            <span id="copy-prompt-preview" aria-live="polite" class="pointer-events-none absolute left-0 top-full mt-3 hidden whitespace-nowrap font-[JetBrains_Mono,monospace] text-xs opacity-0 translate-y-1 transition-all duration-200 ease-out group-hover/copy:translate-y-0 group-hover/copy:opacity-100 group-focus-within/copy:translate-y-0 group-focus-within/copy:opacity-100 group-data-[feedback=true]/copy:translate-y-0 group-data-[feedback=true]/copy:opacity-100 sm:inline-flex">
              <span class="relative inline-flex">
                <span class="inline-flex items-center gap-1 text-gray-500 transition-all duration-200 ease-out group-data-[feedback=true]/copy:-translate-y-1 group-data-[feedback=true]/copy:opacity-0">
                  <span class="relative top-px inline-flex w-3 shrink-0 justify-center text-sm leading-none text-blue-300">&ldquo;</span>
                  <span>{COPY_PROMPT}<span class="relative top-px ml-1 text-sm leading-none text-blue-300">&rdquo;</span></span>
                </span>
                <span id="copy-prompt-feedback" class="absolute left-0 top-0 inline-flex translate-y-1 items-center gap-1 opacity-0 transition-all duration-200 ease-out group-data-[feedback=true]/copy:translate-y-0 group-data-[feedback=true]/copy:opacity-100">
                  <span class="inline-flex w-3 shrink-0 justify-center text-blue-500 group-data-[copy-error=true]/copy:hidden">&#x2713;</span>
                  <span class="hidden w-3 shrink-0 justify-center text-gray-500 group-data-[copy-error=true]/copy:inline-flex">!</span>
                  <span class="text-blue-600 group-data-[copy-error=true]/copy:hidden">Copied — now paste that into your coding agent for a guided walkthrough!</span>
                  <span class="hidden text-gray-600 group-data-[copy-error=true]/copy:inline">Could not copy prompt</span>
                </span>
              </span>
            </span>
          </div>
          <script id="copy-prompt-text" type="text/plain" set:html={COPY_PROMPT}></script>
          <a href="/docs/" class="group inline-flex items-center gap-2.5 border border-gray-300 hover:border-gray-400 bg-white hover:bg-gray-50 rounded-full px-5 py-3 text-sm font-medium text-gray-700 transition-colors ">
            <svg class="w-5 h-5 text-gray-400 transition-all duration-300 ease-out group-hover:text-gray-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/>
              <line x1="8" y1="17" x2="16" y2="17"/>
            </svg>
            View Documentation
          </a>
        </div>
      </div>
    </section>


    <!-- Hero code snippet, sitting astride the white → gray section break.

         Background gradient hard-cuts at the vertical midpoint so the snippet
         card visually straddles both hero (white) and body (gray) sections. -->
    <section class="relative z-1" style="background: linear-gradient(to bottom, transparent 0%, transparent 50%, #f8f9fb 50%, #f8f9fb 100%);">
      <!-- 1px rule that runs behind the card at the section boundary. -->
      <div class="absolute top-1/2 left-0 right-0 h-px bg-gray-300 transform -translate-y-1/2 z-0"></div>

      <div class="max-w-6xl mx-auto px-6 py-16 relative z-10">
        <div class="hero-code border border-gray-300 rounded-sm overflow-hidden shadow-lg bg-white/70 backdrop-blur-sm [&_pre]:p-6 [&_pre]:text-sm [&_pre]:leading-relaxed [&_pre]:overflow-x-auto [&_pre]:m-0 [&_pre]:rounded-none [&_pre]:bg-transparent">
          <!-- Code block chrome: filename (left) + run modes (right). -->
          <div class="flex items-stretch border-b border-gray-200 bg-gray-50/60">
            <div class="flex items-center gap-2 px-4 py-2.5 min-w-0">
              <svg class="w-3.5 h-3.5 text-blue-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
              <span class="font-[JetBrains_Mono,monospace] text-[13px] text-gray-600 truncate">agents/triage.ts</span>
            </div>

            <div class="ml-auto flex items-stretch divide-x divide-gray-200 border-l border-gray-200">
              <!-- CLI agent interaction mode -->
              <div class="hidden md:flex items-baseline gap-2 px-4 py-2.5" title="Connect to a persistent agent instance from the CLI">
                <svg class="w-3.5 h-3.5 text-blue-500 shrink-0 self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="4 17 10 11 4 5"/>
                  <line x1="12" y1="19" x2="20" y2="19"/>
                </svg>
                <span class="font-[JetBrains_Mono,monospace] text-[13px] text-gray-600">flue connect triage</span>
              </div>
              <!-- HTTP agent interaction mode -->
              <div class="hidden sm:flex items-baseline gap-2 px-4 py-2.5" title="Prompt a persistent agent instance over HTTP">
                <svg class="w-3.5 h-3.5 text-blue-500 shrink-0 self-center" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                <span class="font-[JetBrains_Mono,monospace] text-[13px] text-gray-600">POST /agents/triage/:id</span>
              </div>

            </div>
          </div>
          <Code code={HERO} lang="typescript" theme="github-light" />
        </div>
      </div>
    </section>

    <!-- Body sections — off-white background wraps everything below the hero. -->
    <div class="bg-[#f8f9fb]">

    <!-- SECTION: The Universal Agent — what it is, and why Flue. -->
    <section>
      <div class="max-w-6xl mx-auto px-6 py-24">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
          <div class="lg:col-span-7">
            <h2 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight leading-[1.1] text-balance">
              The framework for building the next generation of agents.
            </h2>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              The first agents were built with raw LLM API calls. This worked for simple chatbots and scripted tasks, but not much else.
            </p>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              Agents like Claude Code and Codex broke the mold. These were <em>real agents.</em> Autonomous. You give them a task — not a pre-defined series of steps — and trust them to complete it using the context and tools that you provide.
            </p>
            <p class="mt-6 text-lg text-gray-600 leading-relaxed">
              <strong>Flue unlocks this new architecture for agents.</strong> Its built-in TypeScript harness gives any model the context and environment it needs for truly autonomous work: sessions, tools, skills, instructions, filesystem access, and a secure sandbox to run in. Run your agents locally via CLI or deploy them to your hosted runtime of choice.
            </p>
          </div>

          <!-- Illustration: Universal Agent Architecture.
               Four stacked blueprint bands (harness → model → sandbox → filesystem,
               top-down in visual order; rendered in reverse via flex-col-reverse
               so the array reads bottom-up like a stack). Each band: schematic
               zone (top) + label bar (bottom). `rows` controls band height in
               grid cells, creating a subtle visual hierarchy. -->
          <div class="lg:col-span-5 flex justify-center">
            <div class="w-full max-w-md relative">
              <p class="text-xs font-medium text-gray-500 uppercase tracking-wider text-center mb-3">Universal Agent Architecture</p>
              <div class="flex flex-col-reverse gap-4">
                {[
                  {
                    key: 'filesystem',
                    label: 'Filesystem',
                    desc: 'read · write · grep · glob',
                    color: '#059669',     // emerald-600 — foundational "ground"
                    textColor: '#047857', // emerald-700 (AA on tinted bg)
                    fillLight: '#dff5ed',
                    fillDark: '#9fd6c2',
                    rows: 3,
                  },
                  {
                    key: 'sandbox',
                    label: 'Sandbox',
                    desc: 'bash · security · network',
                    color: '#d97706',     // amber-600 — boundary/caution
                    textColor: '#b45309', // amber-700 (AA)
                    fillLight: '#fde7d3',
                    fillDark: '#efc19f',
                    rows: 3,
                  },
                  {
                    key: 'agent',
                    label: 'Harness',
                    desc: 'skills · memory · sessions',
                    color: '#8b5cf6',     // violet-500 — AI/intelligence
                    textColor: '#6d28d9', // violet-700 (AA)
                    fillLight: '#eadffc',
                    fillDark: '#c5adf7',
                    rows: 3,
                  },
                  {
                    key: 'model',
                    label: 'Model',
                    desc: 'tokens · tools · prompts',
                    color: '#2563eb',     // blue-600 — vivid, active orchestrator
                    textColor: '#1d4ed8', // blue-700 (AA)
                    fillLight: '#dbe6fd',
                    fillDark: '#a4bdf8',
                    rows: 3,
                  },
                ].map((layer, index) => {
                  // Layer number counts down from the top-visible band (01 at
                  // the top, 04 at the bottom) because the array is bottom-up
                  // but the number reads top-down visually. With 4 layers and
                  // flex-col-reverse, `4 - index` gives 4,3,2,1 which pads to
                  // 04,03,02,01 — matching the top-down reading order.
                  const num = String(4 - index).padStart(2, '0');
                  const cols = 15;
                  const cell = 20;
                  const width = cols * cell;
                  const height = layer.rows * cell;
                  const schematicHeight = (layer.rows - 1) * cell;

                  // Parse hex color into "R G B" triplet for the drop-shadow
                  // filter (see .pattern-layer in global.css).
                  const hex = layer.textColor.replace('#', '');
                  const shadowRgb = `${parseInt(hex.slice(0, 2), 16)} ${parseInt(hex.slice(2, 4), 16)} ${parseInt(hex.slice(4, 6), 16)}`;
                  return (
                    <div class="pattern-layer relative isolate transition-transform duration-300 ease-out hover:-translate-y-px hover:scale-[1.02] hover:z-10 cursor-default" style={`--shadow-rgb: ${shadowRgb}; background: ${layer.fillLight}; animation-delay: ${(3 - index) * 150 + 800}ms;`}>
                      <div
                        class="architecture-shader absolute inset-x-px top-px z-0 pointer-events-none"
                        style={`bottom: ${(100 * cell) / height}%;`}
                        data-ambient-shader
                        data-color-back={layer.fillDark}
                        data-color-front={layer.fillLight}
                        data-shape="simplex"
                        data-type="4x4"
                        data-size="2"
                        data-scale="0.25"
                        data-speed="0.28"
                        data-frame={String(index * 6200)}
                      ></div>
                      <svg
                        viewBox={`0 0 ${width} ${height}`}
                        width="100%"
                        height="100%"
                        xmlns="http://www.w3.org/2000/svg"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                        class="relative z-10 block overflow-visible shadow-sm"
                        style={`aspect-ratio: ${width} / ${height};`}
                      >
                        {/* Schematic zone background + darker label bar. */}
                        <rect x="0" y="0" width={width} height={schematicHeight} fill="transparent"/>
                        <rect x="0" y={schematicHeight} width={width} height={cell} fill={layer.fillDark}/>

                        {/* Separator between schematic and label bar. */}
                        <line x1="0" y1={schematicHeight} x2={width} y2={schematicHeight} stroke={layer.color} stroke-opacity="0.55" stroke-width="1" vector-effect="non-scaling-stroke"/>

                        {/* Outer border — inset 0.5 so the full stroke sits inside the viewBox. */}
                        <rect x="0.5" y="0.5" width={width - 1} height={height - 1} fill="none" stroke={layer.color} stroke-opacity="0.55" stroke-width="1" vector-effect="non-scaling-stroke"/>

                        {/* Corner + separator dot markers — echoes the hero squares. */}
                        <g fill={layer.color} fill-opacity="0.25">
                          <circle cx="0.5"         cy="0.5"          r="1.33" vector-effect="non-scaling-stroke"/>
                          <circle cx={width - 0.5} cy="0.5"          r="1.33" vector-effect="non-scaling-stroke"/>
                          <circle cx="0.5"         cy={height - 0.5} r="1.33" vector-effect="non-scaling-stroke"/>
                          <circle cx={width - 0.5} cy={height - 0.5} r="1.33" vector-effect="non-scaling-stroke"/>
                          <circle cx="0.5"         cy={schematicHeight} r="1.33" vector-effect="non-scaling-stroke"/>
                          <circle cx={width - 0.5} cy={schematicHeight} r="1.33" vector-effect="non-scaling-stroke"/>
                        </g>
                      </svg>

                      {/* Label bar overlay — bottom band, height matches one grid cell. */}
                      <div class="absolute bottom-0 left-0 right-0 z-10 flex items-center justify-between gap-3 px-3 pointer-events-none" style={`height: ${(100 * cell) / height}%;`}>
                        <span class="font-[JetBrains_Mono,monospace] text-[11px] font-semibold tracking-[0.18em] uppercase leading-none" style={`color: ${layer.textColor};`}>
                          <span style="opacity: 0.55;">{num} /</span> {layer.label}
                        </span>
                        <span class="font-[JetBrains_Mono,monospace] text-[11px] tracking-wide truncate leading-none" style={`color: ${layer.textColor};`}>
                          {layer.desc}
                        </span>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

