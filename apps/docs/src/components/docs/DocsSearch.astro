---
import SearchIcon from './SearchIcon.astro';
---

<button class="inline-flex w-50 cursor-pointer items-center gap-2 rounded-lg border border-transparent bg-docs-code py-1.5 transition-colors duration-150 pr-2 pl-3 text-sm leading-none text-gray-600 hover:border-gray-400 hover:text-gray-950 max-docs-desktop:h-9 max-docs-desktop:w-full max-docs-desktop:min-w-0 max-docs-desktop:border-docs-border max-docs-desktop:px-3" type="button" data-search-open aria-label="Search documentation" aria-haspopup="dialog" aria-controls="docs-search-dialog">
	<SearchIcon />
	<span class="text-gray-500">Search</span>
	<kbd class="ml-auto rounded-md py-1 px-1.5 font-sans text-xs text-gray-400 max-docs-desktop:hidden">⌘ K</kbd>
</button>

<dialog id="docs-search-dialog" class="fixed top-18 m-auto w-[min(620px,calc(100%-2rem))] rounded-xl border-0 bg-white p-0 shadow-[0_20px_65px_rgb(15_23_42_/_24%)] backdrop:bg-[rgb(15_23_42_/_32%)] max-docs-desktop:top-2.5 max-docs-desktop:w-[calc(100%-1.25rem)]" aria-label="Search documentation">
	<div class="overflow-hidden rounded-[inherit]" data-search-panel>
		<form class="flex items-center gap-3 border-b border-docs-border p-3" method="dialog">
			<label class="flex flex-1 items-center gap-3 text-docs-subtle">
				<SearchIcon />
				<span class="absolute size-px overflow-hidden [clip-path:inset(50%)] whitespace-nowrap">Search documentation</span>
				<input class="w-full border-0 bg-transparent font-sans text-base text-docs-text outline-none placeholder:text-docs-subtle" type="search" name="query" autocomplete="off" placeholder="Search documentation" data-search-input />
			</label>
			<button class="rounded-md border border-docs-border bg-docs-code py-1 px-2 text-xs text-docs-muted" value="cancel" aria-label="Close search">Esc</button>
		</form>
		<div class="max-h-[min(55vh,430px)] overflow-y-auto p-2" data-search-results aria-live="polite">
			<p class="search-empty">Start typing to search the documentation.</p>
		</div>
	</div>
</dialog>

<script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
	const dialog = document.querySelector('#docs-search-dialog');
	const panel = dialog?.querySelector('[data-search-panel]');
	const input = dialog?.querySelector('[data-search-input]');
	const results = dialog?.querySelector('[data-search-results]');
	const trigger = document.querySelector('[data-search-open]');
	let requestId = 0;
	let pagefindPromise;

	if (dialog && panel && input && results && trigger) {
		const fallbackUrl = `${baseUrl}getting-started/quickstart/`;
		const escapeHtml = (value) => value.replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;');
		const safeUrl = (value) => {
			try {
				const url = new URL(value ?? fallbackUrl, window.location.origin);
				if (url.origin !== window.location.origin || (url.protocol !== 'http:' && url.protocol !== 'https:')) return fallbackUrl;
				const pathname = url.pathname === baseUrl.slice(0, -1) || url.pathname.startsWith(baseUrl) ? url.pathname : `${baseUrl}${url.pathname.replace(/^\/+/, '')}`;
				return `${pathname}${url.search}${url.hash}`;
			} catch {
				return fallbackUrl;
			}
		};
		const loadPagefind = () => {
			pagefindPromise ??= import(`${baseUrl}pagefind/pagefind.js`).then(async (pagefind) => {
				await pagefind.options({ baseUrl });
				await pagefind.init();
				return pagefind;
			});
			return pagefindPromise;
		};
		const renderState = (content) => {
			results.innerHTML = `<p class="search-empty">${escapeHtml(content)}</p>`;
		};
		const closeSearch = () => dialog.close();
		const openSearch = () => {
			dialog.showModal();
			input.focus();
			void loadPagefind().catch(() => undefined);
		};

		trigger.addEventListener('click', openSearch);
		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) closeSearch();
		});
		document.addEventListener('keydown', (event) => {
			if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
				event.preventDefault();
				openSearch();
			}
		});

		input.addEventListener('input', async () => {
			const query = input.value.trim();
			const thisRequest = ++requestId;
			if (!query) {
				renderState('Start typing to search the documentation.');
				return;
			}
			renderState('Searching…');
			try {
				const pagefind = await loadPagefind();
				const response = await pagefind.search(query);
				const hits = await Promise.all(response.results.slice(0, 8).map((result) => result.data()));
				if (thisRequest !== requestId) return;
				if (hits.length === 0) {
					renderState(`No results for “${query}”.`);
					return;
				}
				results.innerHTML = hits.map((hit) => {
					const title = escapeHtml(hit.meta.title ?? 'Documentation page');
					const url = escapeHtml(safeUrl(hit.url));
					return `<a class="search-result" href="${url}"><strong>${title}</strong><p>${hit.excerpt}</p></a>`;
				}).join('');
			} catch {
				if (thisRequest === requestId) renderState('Search is available after building the documentation site.');
			}
		});
	}
</script>
