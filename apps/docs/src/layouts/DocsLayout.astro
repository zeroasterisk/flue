---
import type { MarkdownHeading } from 'astro';
import DocsCover from '../components/docs/DocsCover.astro';
import DocsHeader from '../components/docs/DocsHeader.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsTableOfContents from '../components/docs/DocsTableOfContents.astro';
import MobileDocsNavigation from '../components/docs/MobileDocsNavigation.astro';
import { docsHref, docsSections, getDocsSection } from '../lib/docs-navigation';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	lastReviewedAt?: Date;
	currentSlug: string;
	headings: MarkdownHeading[];
	showTableOfContents?: boolean;
}

const {
	title,
	description,
	lastReviewedAt,
	currentSlug,
	headings,
	showTableOfContents = true,
} = Astro.props;
const tableOfContents = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const coverVariant = currentSlug === 'concepts/agents' ? 'agents' : currentSlug === 'introduction/why-flue' ? 'workflows' : undefined;
const currentSection = getDocsSection(currentSlug);
const markdownUrl = `${import.meta.env.BASE_URL}${currentSlug}/index.md`;
const pageTitle = `${title} | Flue`;
const pageDescription = description ?? 'Flue framework documentation.';
const canonicalUrl = new URL(Astro.url.pathname, 'https://flueframework.com').href;
const reviewedDate = lastReviewedAt?.toISOString().slice(0, 10);
const formattedReviewedDate = lastReviewedAt?.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
	timeZone: 'UTC',
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon-96x96.png`} sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="shortcut icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
		<link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#ffffff" />
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Flue" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content="https://flueframework.com/docs/og3.jpg" />
		<meta property="og:image:alt" content="Flue framework logo" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content="https://flueframework.com/docs/og3.jpg" />
		<meta name="twitter:image:alt" content="Flue framework logo" />
		<title>{pageTitle}</title>
		<link rel="alternate" type="text/markdown" href={markdownUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<a class="fixed left-4 -top-16 z-[100] rounded-lg bg-blue-500 px-3 py-2 text-white focus:top-4" href="#main-content">Skip to content</a>
		<DocsHeader currentSlug={currentSlug} />
		<MobileDocsNavigation groups={currentSection.groups} currentSlug={currentSlug} sectionTitle={currentSection.title} />
		<div class="mx-auto grid min-h-[calc(100vh-var(--docs-header-height))] w-[min(100%,var(--docs-frame-width))] grid-cols-[254px_minmax(0,820px)_16.5rem] max-2xl:grid-cols-[232px_minmax(0,1fr)] max-docs-desktop:block">
			<aside class="border-r border-docs-border pt-[var(--docs-aside-top)] pr-8 pb-8 pl-5 max-docs-desktop:hidden">
				<DocsSidebar groups={currentSection.groups} currentSlug={currentSlug} />
			</aside>
			<main
				id="main-content"
				class:list={[
					'min-w-0 px-[clamp(2.6rem,4vw,4.45rem)] pb-14 max-docs-desktop:px-4 max-docs-desktop:pb-10',
					coverVariant ? 'pt-8 max-docs-desktop:pt-5' : 'pt-12 max-docs-desktop:pt-8',
				]}
			>
				<article data-markdown-content class="mx-auto max-w-175">
					<header class="mb-8 border-b border-docs-border pb-3 max-docs-desktop:mb-7">
						{coverVariant && <DocsCover variant={coverVariant} />}
						<h1 data-pagefind-body class="m-0 text-5xl font-bold leading-[1.08] tracking-[-0.05em] text-gray-950 max-docs-desktop:text-[2.375rem]">{title}</h1>
						<div class:list={['flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 max-docs-desktop:gap-x-4 mt-4 max-docs-desktop:mt-3 place-content-between sm:place-content-start']}>
							{
								lastReviewedAt ? (
										<span>Last updated <time datetime={reviewedDate} data-review-date title={formattedReviewedDate}>{formattedReviewedDate}</time></span>

								) : (
									<span>AI-generated, awaiting review</span>
								)
							}
							<a class="inline-flex items-center gap-2 text-gray-500 transition-colors hover:text-gray-800" href={markdownUrl}>
								<svg class="size-[1.25rem] shrink-0 fill-current" aria-hidden="true" viewBox="0 0 640 640"><path d="M593.8 123.1L46.2 123.1C20.7 123.1 0 143.8 0 169.2L0 470.7C0 496.2 20.7 516.9 46.2 516.9L593.9 516.9C619.4 516.9 640.1 496.2 640 470.8L640 169.2C640 143.8 619.3 123.1 593.8 123.1zM338.5 424.6L277 424.6L277 304.6L215.5 381.5L154 304.6L154 424.6L92.3 424.6L92.3 215.4L153.8 215.4L215.3 292.3L276.8 215.4L338.3 215.4L338.3 424.6L338.5 424.6zM473.8 427.7L381.5 320L443 320L443 215.4L504.5 215.4L504.5 320L566 320L473.8 427.7z" /></svg>
								View as Markdown
							</a>
						</div>
					</header>
					<div class="docs-content" data-pagefind-body>
						<slot />
					</div>
				</article>
				<section data-markdown-navigation class="hidden">
					<h2>Docs Navigation</h2>
					<p>Current page: <a href={docsHref(currentSlug)}>{title}</a></p>
					<h3>Sections</h3>
					<ul>
						{docsSections.map((section) => <li><a href={docsHref(section.landingSlug)}>{section.title}</a></li>)}
					</ul>
					<DocsSidebar groups={currentSection.groups} currentSlug={currentSlug} groupHeadingLevel={3} />
				</section>
			</main>
			<aside class="pt-[var(--docs-aside-top)] pr-2 pb-8 pl-7 max-2xl:hidden">
				{showTableOfContents && <DocsTableOfContents headings={tableOfContents} />}
			</aside>
		</div>
		<script is:inline>
			const setActiveSidebarLink = () => {
				const currentUrl = new URL(window.location.href);

				for (const link of document.querySelectorAll('[data-docs-sidebar-link]')) {
					const linkUrl = new URL(link.href);
					const pageActive = linkUrl.pathname === currentUrl.pathname && linkUrl.hash === '';
					const locationActive = linkUrl.pathname === currentUrl.pathname && linkUrl.hash !== '' && linkUrl.hash === currentUrl.hash;
					const visuallyActive = pageActive || locationActive;
					link.classList.toggle('font-medium', visuallyActive);
					link.classList.toggle('text-blue-600', pageActive);
					link.classList.toggle('text-black', locationActive);
					link.classList.toggle('text-gray-600', !visuallyActive);
					link.classList.toggle('hover:text-gray-950', !visuallyActive);
					link.parentElement?.classList.toggle('docs-sidebar-location-active', locationActive);

					if (locationActive) {
						link.setAttribute('aria-current', 'location');
					} else if (pageActive && currentUrl.hash === '') {
						link.setAttribute('aria-current', 'page');
					} else {
						link.removeAttribute('aria-current');
					}
				}
			};

			setActiveSidebarLink();
			window.addEventListener('hashchange', setActiveSidebarLink);

			for (const heading of document.querySelectorAll('.docs-content :is(h2, h3, h4, h5, h6)[id]')) {
				if (!heading.id) continue;

				const anchor = document.createElement('a');
				anchor.className = 'docs-heading-anchor';
				anchor.href = `#${heading.id}`;
				anchor.setAttribute('aria-label', `Link to ${heading.textContent ?? 'section'}`);
				anchor.textContent = '#';
				heading.append(anchor);
			}

			for (const time of document.querySelectorAll('[data-review-date]')) {
				if (!time.dateTime) continue;

				const reviewedAt = new Date(`${time.dateTime}T00:00:00Z`);
				const now = new Date();
				const dayDifference = Math.floor((Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()) - reviewedAt.getTime()) / 86_400_000);

				if (dayDifference < 0 || dayDifference >= 30) continue;

				if (dayDifference === 0) {
					time.textContent = 'today';
				} else if (dayDifference === 1) {
					time.textContent = 'yesterday';
				} else {
					time.textContent = `${dayDifference} days ago`;
				}
			}
		</script>
	</body>
</html>
