---
import type { MarkdownHeading } from 'astro';
import DocsHeader from '../components/docs/DocsHeader.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsTableOfContents from '../components/docs/DocsTableOfContents.astro';
import MobileDocsNavigation from '../components/docs/MobileDocsNavigation.astro';
import { getDocsSection } from '../lib/docs-navigation';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	lastReviewedAt?: Date;
	currentSlug: string;
	headings: MarkdownHeading[];
	showTableOfContents?: boolean;
}

const {
	title,
	description,
	lastReviewedAt,
	currentSlug,
	headings,
	showTableOfContents = true,
} = Astro.props;
const tableOfContents = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const currentSection = getDocsSection(currentSlug);
const markdownUrl = `/${currentSlug}.md`;
const suggestChangesUrl = 'https://github.com/withastro/flue/issues/new';
const reviewedDate = lastReviewedAt?.toISOString().slice(0, 10);
const formattedReviewedDate = lastReviewedAt?.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
	timeZone: 'UTC',
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#ffffff" />
		<meta name="description" content={description ?? 'Flue framework documentation.'} />
		<title>{title} | Flue</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
	</head>
	<body>
		<a class="fixed left-4 -top-16 z-[100] rounded-lg bg-blue-500 px-3 py-2 text-white focus:top-4" href="#main-content">Skip to content</a>
		<DocsHeader currentSlug={currentSlug} />
		<MobileDocsNavigation groups={currentSection.groups} currentSlug={currentSlug} sectionTitle={currentSection.title} />
		<div class="mx-auto grid min-h-[calc(100vh-var(--docs-header-height))] w-[min(100%,var(--docs-frame-width))] grid-cols-[254px_minmax(0,820px)_14.75rem] max-2xl:grid-cols-[232px_minmax(0,1fr)] max-docs-desktop:block">
			<aside class="border-r border-docs-border pt-[var(--docs-aside-top)] pr-8 pb-8 pl-5 max-docs-desktop:hidden">
				<DocsSidebar groups={currentSection.groups} currentSlug={currentSlug} />
			</aside>
			<main id="main-content" class="min-w-0 pt-12 px-[clamp(2.6rem,4vw,4.45rem)] pb-14 max-docs-desktop:pt-8 max-docs-desktop:px-4 max-docs-desktop:pb-10">
				<article class="mx-auto max-w-175">
					<header class="mb-8 border-b border-docs-border pb-3 max-docs-desktop:mb-7">
						<h1 class="m-0 text-[3.25rem] font-semibold leading-[1.08] tracking-[-0.05em] text-gray-950 max-docs-desktop:text-[2.375rem]">{title}</h1>
						<div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-500 max-docs-desktop:mt-3 max-docs-desktop:gap-x-4">
							{
								lastReviewedAt ? (
									<span class="inline-flex items-center gap-2">
										<svg class="size-[1.125rem] shrink-0 fill-current" aria-hidden="true" viewBox="0 0 640 640"><path d="M175.3 160C161.3 160 148.8 169.2 144.7 182.6L102.4 320L256 320C273.7 320 288 334.3 288 352L352 352C352 334.3 366.3 320 384 320L537.6 320L495.3 182.6C491.2 169.2 478.8 160 464.7 160L432 160C414.3 160 400 145.7 400 128C400 110.3 414.3 96 432 96L464.7 96C506.8 96 544.1 123.5 556.5 163.8L601.9 311.3C606 324.5 608 338.2 608 352L608 448C608 501 565 544 512 544L448 544C395 544 352 501 352 448L352 416L288 416L288 448C288 501 245 544 192 544L128 544C75 544 32 501 32 448L32 352C32 338.2 34.1 324.5 38.1 311.3L83.5 163.8C95.9 123.5 133.1 96 175.3 96L208 96C225.7 96 240 110.3 240 128C240 145.7 225.7 160 208 160L175.3 160zM96 384L96 448C96 465.7 110.3 480 128 480L192 480C209.7 480 224 465.7 224 448L224 384L96 384zM512 480C529.7 480 544 465.7 544 448L544 384L416 384L416 448C416 465.7 430.3 480 448 480L512 480z" /></svg>
										<span>Last updated <time datetime={reviewedDate} data-review-date title={formattedReviewedDate}>{formattedReviewedDate}</time></span>
									</span>
								) : (
									<span>AI-generated, awaiting review</span>
								)
							}
							<a class="inline-flex items-center gap-2 text-gray-500 transition-colors hover:text-gray-800" href={markdownUrl}>
								<svg class="size-[1.25rem] shrink-0 fill-current" aria-hidden="true" viewBox="0 0 640 640"><path d="M593.8 123.1L46.2 123.1C20.7 123.1 0 143.8 0 169.2L0 470.7C0 496.2 20.7 516.9 46.2 516.9L593.9 516.9C619.4 516.9 640.1 496.2 640 470.8L640 169.2C640 143.8 619.3 123.1 593.8 123.1zM338.5 424.6L277 424.6L277 304.6L215.5 381.5L154 304.6L154 424.6L92.3 424.6L92.3 215.4L153.8 215.4L215.3 292.3L276.8 215.4L338.3 215.4L338.3 424.6L338.5 424.6zM473.8 427.7L381.5 320L443 320L443 215.4L504.5 215.4L504.5 320L566 320L473.8 427.7z" /></svg>
								View as Markdown
							</a>
							<a class="inline-flex items-center gap-2 text-gray-500 transition-colors hover:text-gray-800" href={suggestChangesUrl}>
								<svg class="size-[1.125rem] shrink-0 fill-current" aria-hidden="true" viewBox="0 0 640 640"><path d="M416.9 85.2L372 130.1L509.9 268L554.8 223.1C568.4 209.6 576 191.2 576 172C576 152.8 568.4 134.4 554.8 120.9L519.1 85.2C505.6 71.6 487.2 64 468 64C448.8 64 430.4 71.6 416.9 85.2zM338.1 164L122.9 379.1C112.2 389.8 104.4 403.2 100.3 417.8L64.9 545.6C62.6 553.9 64.9 562.9 71.1 569C77.3 575.1 86.2 577.5 94.5 575.2L222.3 539.7C236.9 535.6 250.2 527.9 261 517.1L476 301.9L338.1 164z" /></svg>
								Suggest changes
							</a>
						</div>
					</header>
					<div class="docs-content">
						<slot />
					</div>
				</article>
			</main>
			<aside class="pt-[var(--docs-aside-top)] pr-2 pb-8 pl-7 max-2xl:hidden">
				{showTableOfContents && <DocsTableOfContents headings={tableOfContents} />}
			</aside>
		</div>
		<script>
			for (const time of document.querySelectorAll<HTMLTimeElement>('[data-review-date]')) {
				if (!time.dateTime) continue;

				const reviewedAt = new Date(`${time.dateTime}T00:00:00Z`);
				const now = new Date();
				const dayDifference = Math.floor((Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()) - reviewedAt.getTime()) / 86_400_000);

				if (dayDifference < 0 || dayDifference >= 30) continue;

				if (dayDifference === 0) {
					time.textContent = 'today';
				} else if (dayDifference === 1) {
					time.textContent = 'yesterday';
				} else {
					time.textContent = `${dayDifference} days ago`;
				}
			}
		</script>
	</body>
</html>
