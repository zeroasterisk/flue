---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Callout from '../components/docs/Callout.astro';
import DocsLayout from '../layouts/DocsLayout.astro';

interface Props {
	entry: CollectionEntry<'docs'>;
	slug: string;
}

export async function getStaticPaths() {
	const entries = await getCollection('docs');

	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry, slug: entry.id },
	}));
}

const { entry, slug } = Astro.props;
const { Content, headings } = await render(entry);
const showTableOfContents = entry.data.tableOfContents !== false;
---

<DocsLayout
	title={entry.data.title}
	description={entry.data.description}
	subtitle={entry.data.subtitle}
	packageLink={entry.data.package}
	lastReviewedAt={entry.data.lastReviewedAt}
	currentSlug={slug}
	headings={headings}
	showTableOfContents={showTableOfContents}
>
	<Content components={{ Callout }} />
</DocsLayout>
