{
	"name": "@flue/runtime",
	"version": "0.7.0",
	"type": "module",
	"license": "Apache-2.0",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./app": {
			"types": "./dist/app.d.mts",
			"import": "./dist/app.mjs"
		},
		"./client": {
			"types": "./dist/client-compat.d.mts",
			"import": "./dist/client-compat.mjs"
		},
		"./sandbox": {
			"types": "./dist/sandbox-compat.d.mts",
			"import": "./dist/sandbox-compat.mjs"
		},
		"./internal": {
			"types": "./dist/internal.d.mts",
			"import": "./dist/internal.mjs"
		},
		"./cloudflare": {
			"types": "./dist/cloudflare/index.d.mts",
			"import": "./dist/cloudflare/index.mjs"
		},
		"./node": {
			"types": "./dist/node/index.d.mts",
			"import": "./dist/node/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./types/index.d.ts",
	"files": [
		"dist",
		"types"
	],
	"engines": {
		"node": ">=22.18.0"
	},
	"scripts": {
		"build": "tsdown",
		"check:types": "tsc --noEmit",
