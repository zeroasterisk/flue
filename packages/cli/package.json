{
	"name": "@flue/cli",
	"version": "0.8.0-beta.6",
	"type": "module",
	"license": "Apache-2.0",
	"bin": {
		"flue": "bin/flue.mjs"
	},
	"exports": {
		"./config": {
			"types": "./dist/config.d.mts",
			"import": "./dist/config.mjs"
		}
	},
	"files": [
		"bin/flue.mjs",
		"dist"
	],
	"engines": {
		"node": ">=22.18.0"
	},
	"scripts": {
		"prebuild": "tsx scripts/generate-connector-index.ts",
		"build": "tsdown && mv dist/flue.mjs dist/flue.js",
		"check:types": "tsc --noEmit",
		"prepublishOnly": "cp ../../README.md ."
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.38.0",
		"@flue/runtime": "workspace:*",
		"@vercel/detect-agent": "^1.2.3",
		"package-up": "^5.0.0",
		"valibot": "^1.0.0",
		"vite": "^8.0.14"
	},
	"devDependencies": {
		"tsdown": "^0.22.0",
		"tsx": "^4.19.2",
		"typescript": "^6.0.3",
		"wrangler": "^4.94.0"
	},
	"peerDependencies": {
		"wrangler": "^4.94.0"
	},
	"peerDependenciesMeta": {
		"wrangler": {
			"optional": true
		}
	}
}
