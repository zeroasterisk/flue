		},
		"./client": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		},
		"./sandbox": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		},
		"./internal": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		},
		"./node": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		},
		"./cloudflare": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		},
		"./config": {
			"types": "./dist/deprecated.d.mts",
			"import": "./dist/deprecated.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.18.0"
	},
	"scripts": {
		"build": "tsdown",
		"check:types": "tsc --noEmit",
